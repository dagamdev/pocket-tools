{
  "manifest_version": 3,
  "name": "Pocket tools",
  "version": "1.2.0",
  "description": "Herramientas para el Broker Pocket Option basado en binarias",
  "permissions": ["scripting", "storage", "tabs"],
  "host_permissions": [
    "https://pocketoption.com/*"
  ],
  "icons": {
    "128": "icon.png"
  },
  "action": {
    "default_popup": "popup/index.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://pocketoption.com/*"
      ], 
      "css": [
        "scripts/styles.css",
        "scripts/modal.css"
      ],
      "js": [
        "utils/constants.js",
        "utils/handlers.js",
        "utils/variables.js",
        "utils/functions.js",
        "utils/chrome.js",
        "events/load.js",
        "events/visibilityChange.js",
        "events/resize.js",
        "events/click.js",
        "events/change.js",
        "scripts/DOM.js",
        "scripts/content.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "matches": ["https://pocketoption.com/*"],
      "resources": ["scripts/background-dark.png"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}